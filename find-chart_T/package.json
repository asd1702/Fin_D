{
  "name": "fin-q-chart-server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/server.js",
    "migrate:create": "dotenv -e .env -- prisma migrate dev --create-only",
    "migrate:deploy": "dotenv -e .env -- prisma migrate deploy",
    "prisma:generate": "dotenv -e .env -- prisma generate",
    "start": "dotenv -e .env -- ts-node src/server.ts",
    "dev": "nodemon --watch src --ignore src/scripts --ext ts --exec \"dotenv -e .env -- ts-node src/server.ts\"",
    "reset": "dotenv -e .env -- ts-node src/scripts/reset-db.ts",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:logs": "docker compose -f docker-compose.db.yml logs -f timescaledb",
    "db:ps": "docker compose -f docker-compose.db.yml ps",
    "db:reset:dev": "dotenv -e .env -- ts-node src/scripts/reset-db.ts",
    "db:setup:dev": "dotenv -e .env -- ts-node src/scripts/setup-ec2-db.ts",
    "seed": "dotenv -e .env -- ts-node src/scripts/seed-historical.ts",
    "seed:symbol": "dotenv -e .env -- ts-node src/scripts/seed-historical.ts --symbol",
    "fill-gaps": "dotenv -e .env -- tsx src/scripts/fill-gaps.ts",
    "refetch": "dotenv -e .env -- tsx src/scripts/refetch-candles.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "envalid": "^8.1.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "p-limit": "^3.1.0",
    "technicalindicators": "^3.1.0",
    "winston": "^3.18.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/p-limit": "^2.2.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.10",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
